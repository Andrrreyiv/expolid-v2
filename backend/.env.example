# ---- Required ----
SECRET_KEY=please-change-to-a-random-32-byte-secret
DATABASE_URL=sqlite:///./data/expolid.db
UPLOAD_DIR=./data/uploads
CORS_ORIGINS=*

# ---- AI providers (any one is enough; OpenAI used as fallback) ----
# Vision (OCR визиток) + chat (резюме / следующий шаг / followup)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Audio (расшифровка голоса) — Whisper-large-v3-turbo, бесплатно
GROQ_API_KEY=

# OpenAI fallback (опционально)
OPENAI_API_KEY=
OPENAI_MODEL_CHAT=gpt-4o
OPENAI_MODEL_VISION=gpt-4o
OPENAI_MODEL_AUDIO=whisper-1

# ---- Integrations (опционально) ----
TELEGRAM_BOT_TOKEN=
# AMOCRM_* подключаются через UI в Настройках, в .env не нужны
